# ─── Database (Neon) ──────────────────────────────────────────────────────────
# Get both from: https://console.neon.tech → your project → Connection Details
# DATABASE_URL uses the pooled connection string (for app queries)
# DIRECT_URL  uses the direct connection string (for Prisma migrations)
# Recommended for most uses
DATABASE_URL=
# For uses requiring a connection without pgbouncer
DIRECT_URL=
# Parameters for constructing your own connection string
PGHOST=
PGHOST_UNPOOLED=
PGUSER=
PGDATABASE=
PGPASSWORD=

# Parameters for Vercel Postgres Templates
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=
POSTGRES_URL_NO_SSL=
POSTGRES_PRISMA_URL=
# ─── Auth.js ──────────────────────────────────────────────────────────────────
# Run: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=

# ─── AI (Gemini) ──────────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Get from: https://resend.com/api-keys
# Use resend.dev domain for testing (no DNS setup needed)
RESEND_API_KEY=
EMAIL_FROM="digest@resend.dev"

# ─── Payments (Stripe) ────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRO_PRICE_ID="price_..."
STRIPE_TEAM_PRICE_ID="price_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ─── YouTube Data API ─────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Enable: YouTube Data API v3
YOUTUBE_API_KEY=

# ─── Security ─────────────────────────────────────────────────────────────────
# Run: openssl rand -hex 32
CRON_SECRET=
# Run: openssl rand -hex 32  (used to AES-encrypt BYOK keys in DB)
ENCRYPTION_KEY=

# ─── Admin ────────────────────────────────────────────────────────────────────
# Email address that can access /admin and /api/admin
ADMIN_EMAIL=""

# Public admin email — used to show the Admin nav link in the UI
# Must match ADMIN_EMAIL above exactly
NEXT_PUBLIC_ADMIN_EMAIL=""
